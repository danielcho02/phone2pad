# Build outputs
pc/build/
pc/build-release/
android/.gradle/
android/.kotlin/
android/build/
android/*/build/
android/local.properties

# IDE
.idea/
.vs/
*.user
out/

# OS
Thumbs.db
.DS_Store

# Driver signing artifacts (never commit — see docs/06-WORKFLOW.md §2)
*.cer
*.pfx
*.cat

# Android release signing — never commit the keystore or its passwords
android/keystore.properties
*.jks
*.keystore

# Release packaging output
dist/

# App-local downloaded Android Platform Tools (never commit Google binaries).
# Users may drop platform-tools next to the client; the repo has no source dir
# named platform-tools, so these patterns can't shadow tracked sources.
/tools/platform-tools/
tools/platform-tools/
/platform-tools/
platform-tools/
