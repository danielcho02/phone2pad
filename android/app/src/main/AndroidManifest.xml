<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Localhost TCP listen for the adb-forwarded PC client. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="phone2pad"
        android:supportsRtl="false"
        android:theme="@style/Theme.phone2pad.Black">

        <!-- Launcher screen: USB setup guide + "start pad" button. Shown when the
             user taps the app icon. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.phone2pad.Main">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Landscape "pad" Activity (black touchpad surface). Exported so the PC
             client can launch it directly via
             `adb shell am start -n com.phone2pad/.BlackPadActivity`. Reachable from
             MainActivity's "start pad" button; no LAUNCHER category (not the icon
             entry point). -->
        <activity
            android:name=".BlackPadActivity"
            android:exported="true"
            android:screenOrientation="sensorLandscape"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden" />
    </application>

</manifest>
