# phone2pad release signing config — TEMPLATE.
#
# Copy this file to `android/keystore.properties` and fill in real values to build
# a release-signed APK/AAB. The real keystore.properties and the .jks/.keystore it
# points to are git-ignored and MUST NOT be committed (see .gitignore).
#
# Create a keystore once (see RELEASE.md for the full procedure):
#   keytool -genkeypair -v -keystore phone2pad-release.jks \
#     -alias phone2pad -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ project root.

storeFile=phone2pad-release.jks
storePassword=CHANGE_ME
keyAlias=phone2pad
keyPassword=CHANGE_ME
